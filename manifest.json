{
  "$schema": "../manifest.schema.json",
  "schemaVersion": 1,
  "id": "money",
  "slug": "money",
  "name": "Money",
  "description": "Personal finance dashboard with own database.",
  "icon": "money",
  "status": "available",
  "sortOrder": 10,
  "agent": {
    "routing": [
      "personal finance",
      "income and expense tracking",
      "wallets and balances",
      "categories",
      "monthly cash flow"
    ],
    "tasks": [
      "record income and expenses",
      "search transactions",
      "summarize spending",
      "manage wallets",
      "manage categories"
    ]
  },
  "source": {
    "repository": "money-template",
    "remote": "git@github.com:llm-to-apps/money-template.git",
    "path": "templates/money"
  },
  "updates": {
    "github": {
      "repository": "llm-to-apps/money-template",
      "ref": "main",
      "path": "manifest.json"
    }
  },
  "git": {
    "mount": {
      "target": "/workspace",
      "strategy": "clone",
      "defaultBranch": "main",
      "preserve": ["node_modules", ".next"]
    }
  },
  "image": "ghcr.io/llm-to-apps/money-template:sha-0226450",
  "runtime": {
    "workdir": "/workspace",
    "appPort": 80,
    "devPort": 4046,
    "agentPort": 7070,
    "restoreCommand": "npm ci",
    "startupCommands": "npm run prisma:generate && npm run db:deploy && npm run db:seed"
  },
  "resources": {
    "memory": {
      "reservationMb": 256,
      "limitMb": 2048
    },
    "cpu": {
      "reservation": 0.05,
      "limit": 1
    }
  },
  "services": {
    "mysql": {
      "required": true,
      "database": "project"
    },
    "oauth": {
      "required": true
    },
    "storage": {
      "required": true
    }
  },
  "env": {
    "template": {
      "NODE_ENV": "development",
      "NEXT_TELEMETRY_DISABLED": "1",
      "PROJECT_ID": "{{app.projectId}}",
      "MYSQL_HOST": "mysql",
      "MYSQL_PORT": "3306",
      "MYSQL_DATABASE": "{{services.mysql.database}}",
      "MYSQL_USER": "{{services.mysql.user}}",
      "MYSQL_PASSWORD": "{{services.mysql.password}}",
      "DATABASE_URL": "mysql://{{services.mysql.user}}:{{services.mysql.password}}@mysql:3306/{{services.mysql.database}}",
      "OAUTH_CLIENT_ID": "{{services.oauth.clientId}}",
      "OAUTH_CLIENT_SECRET": "{{services.oauth.clientSecret}}",
      "AUTH_SECRET": "{{services.oauth.clientSecret}}",
      "OAUTH_ISSUER_URL": "{{services.oauth.issuerUrl}}",
      "OAUTH_AUTHORIZE_URL": "{{services.oauth.authorizeUrl}}",
      "OAUTH_TOKEN_URL": "{{services.oauth.tokenUrl}}",
      "OAUTH_USERINFO_URL": "{{services.oauth.userinfoUrl}}",
      "OAUTH_INTERNAL_TOKEN_URL": "{{services.oauth.internalTokenUrl}}",
      "OAUTH_INTERNAL_USERINFO_URL": "{{services.oauth.internalUserinfoUrl}}",
      "OS7_PROJECT_TOKEN_INTROSPECTION_URL": "{{services.oauth.internalProjectUserTokenIntrospectionUrl}}",
      "PROJECT_SERVICE_API_TOKEN": "{{services.oauth.projectServiceApiToken}}",
      "PROJECT_SERVICE_API_BASE_URI": "{{services.oauth.projectServiceApiBaseUri}}",
      "OAUTH_REQUEST_HOST": "{{services.oauth.requestHost}}",
      "S3_ENDPOINT": "{{services.storage.internalEndpoint}}",
      "S3_REGION": "{{services.storage.region}}",
      "S3_ACCESS_KEY_ID": "{{services.storage.accessKeyId}}",
      "S3_SECRET_ACCESS_KEY": "{{services.storage.secretAccessKey}}",
      "S3_BUCKET": "{{services.storage.bucket}}",
      "S3_FORCE_PATH_STYLE": "{{services.storage.forcePathStyle}}"
    }
  }
}
