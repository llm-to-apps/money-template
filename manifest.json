{
  "$schema": "../manifest.schema.json",
  "schemaVersion": 1,
  "id": "money",
  "slug": "money",
  "name": "Money",
  "description": "Personal finance dashboard with own database.",
  "icon": "money",
  "status": "available",
  "sortOrder": 10,
  "source": {
    "repository": "money-template",
    "remote": "git@github.com:llm-to-apps/money-template.git",
    "path": "templates/money"
  },
  "git": {
    "mount": {
      "target": "/workspace",
      "strategy": "clone",
      "defaultBranch": "main"
    }
  },
  "image": "ghcr.io/llm-to-apps/money-template:sha-86352ce",
  "runtime": {
    "workdir": "/workspace",
    "appPort": 3001,
    "agentPort": 7070,
    "startupCommands": "npm run db:deploy && npm run db:seed",
    "appCommand": "npm run dev"
  },
  "resources": {
    "memory": {
      "reservationMb": 128,
      "limitMb": 1024
    },
    "cpu": {
      "reservation": 0.05,
      "limit": 1
    }
  },
  "services": {
    "mysql": {
      "required": true,
      "database": "project"
    }
  },
  "env": {
    "template": {
      "NODE_ENV": "development",
      "NEXT_TELEMETRY_DISABLED": "1",
      "MYSQL_HOST": "mysql",
      "MYSQL_PORT": "3306",
      "MYSQL_DATABASE": "{{services.mysql.database}}",
      "MYSQL_USER": "{{services.mysql.user}}",
      "MYSQL_PASSWORD": "{{services.mysql.password}}",
      "DATABASE_URL": "mysql://{{services.mysql.user}}:{{services.mysql.password}}@mysql:3306/{{services.mysql.database}}"
    }
  }
}
